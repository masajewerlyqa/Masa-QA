# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY


# Site URL for auth redirects, emails, and OG (e.g. https://masa.example.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Google/Apple OAuth: in Supabase → Authentication → URL Configuration, add redirect URLs:
#   http://localhost:3000/auth/callback
#   https://YOUR-PRODUCTION-DOMAIN/auth/callback
# Use the same host you open in the browser (localhost vs 127.0.0.1 must match).
# In Google Cloud Console → OAuth client, the authorized redirect URI is Supabase’s callback:
#   https://<project-ref>.supabase.co/auth/v1/callback

# Transactional email — Resend HTTPS API only (no SMTP). Links use NEXT_PUBLIC_SITE_URL.
RESEND_API_KEY=
# Default transactional sender (welcome, orders, security) — verify in Resend
RESEND_FROM_EMAIL="MASA <hello@mail.masajewelry.com>"
# Webhook signing secret — in Resend → Webhooks, endpoint URL = your live site + /api/webhooks/resend
# Example: https://masajewelry.com/api/webhooks/resend (same host as production NEXT_PUBLIC_SITE_URL; must be HTTPS, publicly reachable)
# RESEND_WEBHOOK_SECRET=whsec_...

# Contact form — internal copy: To = who receives submissions (support team inbox)
CONTACT_INBOX_FROM_EMAIL="MASA <support@masajewelry.com>"
CONTACT_SUPPORT_EMAIL=support@masajewelry.com
# Optional CC (comma-separated) — Gmail backup if M365 delays support@ (Resend SMTP 421)
# CONTACT_SUPPORT_CC=masajewelry.qa@gmail.com

# Contact form — “we received your message” to the visitor only (noreply → user)
CONTACT_ACK_FROM_EMAIL="MASA <noreply@masajewelry.com>"
#
# Resend “delivery delayed” + smtp 421 4.4.1 “Failed to establish connection” to @masajewelry.com:
# - This is Resend connecting to *your* Microsoft 365 inbound MX — not a bug in Next.js. Transient M365 / network / throttling.
# - Fix with M365 admin: review connectors, Defender policies, IP allowlisting for Resend (see Resend docs / support).
# - App workarounds: CONTACT_SUPPORT_CC to a non-M365 address; try CONTACT_INBOX_FROM_EMAIL="MASA <hello@mail.masajewelry.com>"
#   so From ≠ To; verify SPF/DKIM in Resend for your domain.
# - Quarantine / Junk on support@; server logs include resendId for Resend → Emails.

# When true, profile UI shows enforcement copy; OTP must still be implemented before hard-blocking flows.
# NEXT_PUBLIC_ENFORCE_PHONE_VERIFICATION=false

# Optional: migration 030 adds profiles.welcome_email_sent_at for idempotent welcome emails

# Footer “Get the app” links (App Store / Google Play). Leave unset until apps are live; icons show as disabled.
# NEXT_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/app/masa/id000000000
# NEXT_PUBLIC_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.masa.app

# Gold & silver: GoldAPI.io (XAU/XAG USD/oz → QAR/gram). https://www.goldapi.io
# GOLDAPI_KEY=goldapi-xxxxxxxx-io

# Optional: Qatar scrape cache for /api/gold-prices + getGoldPrice (off by default; use GoldAPI only).
# GOLD_PRICE_USE_SCRAPER=true
# CRON_SECRET=long-random-string  — only if you re-add a cron for /api/cron/refresh-gold-prices in vercel.json
